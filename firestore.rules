rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function getRole() {
      return get(/databases/$(database)/documents/facilities/higashikurume/staff/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isAuth() && getRole() in ['developer','admin','sub_admin'];
    }
    function canEditSchedule() {
      return isAuth() && getRole() in ['developer','admin','sub_admin','editor'];
    }

    match /facilities/{facilityId} {

      // 職員
      match /staff/{staffId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == staffId;
        allow update, delete: if isAdmin();
      }

      // 児童
      match /children/{childId} {
        allow read: if isAuth();
        allow write: if isAdmin();
      }

      // スケジュール
      match /schedules/{yearMonth} {
        allow read: if isAuth();
        allow write: if canEditSchedule();
      }

      // セッション（コマ割り当て・出欠）
      match /sessions/{sessionDate} {
        allow read, write: if isAuth();
      }

      // つなぎメモ
      match /memos/{memoId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update: if isAuth(); // 既読更新
        allow delete: if isAdmin();
      }

      // アイデアポスト（匿名投稿・リアクション・コメント）
      match /ideas/{ideaId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update: if isAuth(); // リアクション・コメント追加
        allow delete: if isAdmin();
      }

      // ひやりメモ
      match /hazards/{hazardId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // ありがとうカード
      match /thanks/{thankId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update, delete: if isAdmin();
      }

      // こころのひだまり（本人のみ）
      match /hidamari/{userId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
        match /logs/{logDate} {
          allow read, write: if isAuth() && request.auth.uid == userId;
        }
      }

      // こころのひだまり 要約（管理者のみ閲覧）
      match /hidamari_summaries/{summaryId} {
        allow read: if isAdmin();
        allow create: if isAuth();
        allow update, delete: if isAdmin();
      }

      // まとめレポート
      match /reports/{reportId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
